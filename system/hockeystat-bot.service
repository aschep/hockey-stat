[Unit]
Description=Telegram Hockey Bot
After=network.target

[Service]
Type=simple
User=hockey_bot
Group=hockey_bot
WorkingDirectory=/opt/hockey_bot
ExecStart=/opt/hockey_bot/start_bot
Restart=always
RestartSec=5

StandardOutput=append:/var/log/hs_bot/bot.log
StandardError=append:/var/log/hs_bot/bot.log

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/opt/hockey_bot

[Install]
WantedBy=multi-user.target